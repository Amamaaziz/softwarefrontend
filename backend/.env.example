# # .env.example — copy to .env and fill in. Matches config/env.js validation.

# NODE_ENV=development
# PORT=5000

# # PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/nexbyte

# # JWT secrets — must be at least 32 characters each. Use long random strings.
# JWT_SECRET=replace-with-a-long-random-32char-plus-secret
# JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
# ACCESS_TOKEN_EXPIRY=15m
# REFRESH_TOKEN_EXPIRY=7d

# # Single hardcoded admin. Store bcrypt HASHES, never plaintext passwords.
# # DUMMY_PASSWORD_HASH is a valid bcrypt hash of any throwaway string; it exists
# # so login can do a constant-time compare when the email doesn't match (defeats
# # timing attacks that would otherwise reveal whether an email exists).
# ADMIN_EMAIL=admin@nexbyte.com
# ADMIN_PASSWORD_HASH=$2a$12$replace_with_real_bcrypt_hash
# DUMMY_PASSWORD_HASH=$2a$12$replace_with_any_bcrypt_hash

# # Comma-separated CORS allowlist (no trailing slash). Leave empty in dev to
# # allow all. In production, list every frontend + the admin subdomain.
# CORS_ORIGINS=https://nexbyte.com,https://www.nexbyte.com,https://admin.nexbyte.com

# # Set only if cookies must be shared across subdomains (e.g. .nexbyte.com).
# # COOKIE_DOMAIN=.nexbyte.com

# # Upload directory (relative to project root)
# UPLOAD_DIR=uploads
